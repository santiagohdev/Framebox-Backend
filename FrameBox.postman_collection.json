{
  "info": {
    "name": "FrameBox API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://framebox-backend.vercel.app/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan\",\n  \"email\": \"juan@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan@test.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/verify/:token"
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/movies"
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/movies/:id"
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/movies",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Matrix\",\n  \"year\": 1999,\n  \"genre\": \"<genreId>\",\n  \"description\": \"...\",\n  \"status\": \"Pendiente\"\n}"
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/movies/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Vista\",\n  \"rating\": 5\n}"
            }
          }
        },
        {
          "name": "Toggle Favorite",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/movies/:id/favorite"
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/movies/:id"
          }
        }
      ]
    },
    {
      "name": "Genres",
      "item": [
        {
          "name": "Get All",
          "request": { "method": "GET", "url": "{{baseUrl}}/genres" }
        },
        {
          "name": "Get By Id",
          "request": { "method": "GET", "url": "{{baseUrl}}/genres/:id" }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/genres",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Acción\"\n}" }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/genres/:id",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Ciencia ficción\"\n}" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/genres/:id"
          }
        }
      ]
    }
  ]
}
